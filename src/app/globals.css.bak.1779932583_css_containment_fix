@import "tailwindcss";
@import "tw-animate-css";


@custom-variant dark (&:is(.dark *));

:root {
  --background: 0 0% 100%;
  --foreground: 222 11% 11%;

  --card: 0 0% 100%;
  --card-foreground: 222 11% 11%;

  --popover: 0 0% 100%;
  --popover-foreground: 222 11% 11%;

  /* Gemini Vibrant Blue */
  --primary: 217 91% 60%;
  --primary-foreground: 0 0% 100%;

  --secondary: 220 14% 96%;
  --secondary-foreground: 222 11% 11%;

  --muted: 220 14% 96%;
  --muted-foreground: 220 9% 46%;

  /* Gemini Coral Accent */
  --accent: 14 100% 75%;
  --accent-foreground: 222 47% 11%;

  --destructive: 0 84% 60%;
  --destructive-foreground: 0 0% 98%;

  --border: 220 13% 91%;
  --input: 220 13% 91%;
  --ring: 217 91% 60%;

  --radius: 0.875rem;

  /* Jarvis vibrant accents */
  --jarvis-emerald: 158 64% 52%;
  --jarvis-purple: 271 76% 53%;
  --jarvis-amber: 38 92% 50%;
  --jarvis-pink: 330 81% 60%;

  /* Gemini-style gradient backgrounds */
  --gradient-mesh: radial-gradient(at 0% 0%, hsl(217 91% 90%) 0%, transparent 50%),
                   radial-gradient(at 100% 0%, hsl(271 76% 90%) 0%, transparent 50%),
                   radial-gradient(at 50% 100%, hsl(14 100% 92%) 0%, transparent 50%);

  /* === Spatial Glass palette (Jarvis Liquid Glass) === */
  --glass-bg-primary: rgb(255 255 255 / 0.02);
  --glass-bg-elevated: rgb(255 255 255 / 0.04);
  --glass-bg-overlay: rgb(0 0 0 / 0.4);
  --glass-border: rgb(255 255 255 / 0.05);
  --glass-border-strong: rgb(255 255 255 / 0.08);
  --glass-accent: #10b981;
  --glass-accent-glow: rgb(16 185 129 / 0.15);
  --glass-text: #f4f4f5;
  --glass-text-dim: #a1a1aa;
  --glass-base: #0a0a0f;
}

.dark {
  --background: 222 24% 5%;
  --foreground: 210 20% 98%;

  --card: 222 22% 7%;
  --card-foreground: 210 20% 98%;

  --popover: 222 22% 7%;
  --popover-foreground: 210 20% 98%;

  --primary: 217 91% 65%;
  --primary-foreground: 222 47% 11%;

  --secondary: 217 19% 12%;
  --secondary-foreground: 210 20% 98%;

  --muted: 217 19% 12%;
  --muted-foreground: 217 11% 65%;

  --accent: 14 100% 70%;
  --accent-foreground: 222 47% 11%;

  --destructive: 0 84% 60%;
  --destructive-foreground: 0 0% 98%;

  --border: 217 19% 15%;
  --input: 217 19% 15%;
  --ring: 217 91% 65%;

  --gradient-mesh: radial-gradient(at 0% 0%, hsl(217 91% 25% / 0.4) 0%, transparent 50%),
                   radial-gradient(at 100% 0%, hsl(271 76% 25% / 0.4) 0%, transparent 50%),
                   radial-gradient(at 50% 100%, hsl(14 100% 30% / 0.3) 0%, transparent 50%);
}

@theme inline {
  --color-background: hsl(var(--background));
  --color-foreground: hsl(var(--foreground));
  --color-card: hsl(var(--card));
  --color-card-foreground: hsl(var(--card-foreground));
  --color-popover: hsl(var(--popover));
  --color-popover-foreground: hsl(var(--popover-foreground));
  --color-primary: hsl(var(--primary));
  --color-primary-foreground: hsl(var(--primary-foreground));
  --color-secondary: hsl(var(--secondary));
  --color-secondary-foreground: hsl(var(--secondary-foreground));
  --color-muted: hsl(var(--muted));
  --color-muted-foreground: hsl(var(--muted-foreground));
  --color-accent: hsl(var(--accent));
  --color-accent-foreground: hsl(var(--accent-foreground));
  --color-destructive: hsl(var(--destructive));
  --color-border: hsl(var(--border));
  --color-input: hsl(var(--input));
  --color-ring: hsl(var(--ring));
  --radius-sm: calc(var(--radius) - 4px);
  --radius-md: calc(var(--radius) - 2px);
  --radius-lg: var(--radius);
  --radius-xl: calc(var(--radius) + 4px);
}

@layer base {
  * { border-color: hsl(var(--border)); }
  body {
    background: hsl(var(--background));
    color: hsl(var(--foreground));
    font-family: 'Inter', 'SF Pro Display', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    font-feature-settings: "rlig" 1, "calt" 1;
    -webkit-font-smoothing: antialiased;
  }
  code, pre, kbd, samp {
    font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', 'SF Mono', 'Source Code Pro', Menlo, monospace;
  }
  .gemini-mesh { background-image: var(--gradient-mesh); }
  .glass {
    background: hsl(var(--card) / 0.6);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border: 1px solid hsl(var(--border) / 0.5);
  }
  @keyframes shimmer {
    0% { background-position: -200% 0; }
    100% { background-position: 200% 0; }
  }
  .jarvis-shimmer {
    background: linear-gradient(110deg, transparent 30%, hsl(var(--primary) / 0.15) 50%, transparent 70%);
    background-size: 200% 100%;
    animation: shimmer 2.5s ease-in-out infinite;
  }

  /* === Spatial Glass utility classes === */
  .glass-panel {
    background: var(--glass-bg-primary);
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    border: 1px solid var(--glass-border);
  }
  .glass-elevated {
    background: var(--glass-bg-elevated);
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    border: 1px solid var(--glass-border-strong);
  }
  .glass-overlay {
    background: var(--glass-bg-overlay);
    backdrop-filter: blur(40px) saturate(180%);
    -webkit-backdrop-filter: blur(40px) saturate(180%);
  }
  .glass-border {
    border: 1px solid var(--glass-border);
  }
  .glass-glow {
    box-shadow: 0 0 30px var(--glass-accent-glow), 0 0 60px rgb(16 185 129 / 0.05);
  }

  /* === Smooth scrollbar (thin, translucent) === */
  ::-webkit-scrollbar {
    width: 5px;
    height: 5px;
  }
  ::-webkit-scrollbar-track {
    background: transparent;
  }
  ::-webkit-scrollbar-thumb {
    background: rgb(255 255 255 / 0.08);
    border-radius: 9999px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: rgb(255 255 255 / 0.15);
  }
  /* Firefox */
  * {
    scrollbar-width: thin;
    scrollbar-color: rgb(255 255 255 / 0.08) transparent;
  }
}


/* === Chat Lifecycle Animations (May 27 PRD) === */
@keyframes fade-in {
  from { opacity: 0; transform: translateY(4px); }
  to { opacity: 1; transform: translateY(0); }
}
.animate-fade-in {
  animation: fade-in 0.3s ease-out;
}

@keyframes slide-down {
  from { opacity: 0; max-height: 0; transform: translateY(-8px); }
  to { opacity: 1; max-height: 500px; transform: translateY(0); }
}
.animate-slide-down {
  animation: slide-down 0.4s cubic-bezier(0.16, 1, 0.3, 1);
}

@keyframes aurora-shift {
  0%, 100% { transform: translate(0, 0) rotate(0deg) scale(1); }
  33% { transform: translate(30px, -20px) rotate(120deg) scale(1.05); }
  66% { transform: translate(-20px, 25px) rotate(240deg) scale(0.95); }
}
.animate-aurora-shift {
  animation: aurora-shift 18s ease-in-out infinite;
}

@keyframes aurora-shift-1 {
  0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
  25%      { transform: translate3d(40px, -30px, 0) scale(1.1); }
  50%      { transform: translate3d(-20px, 40px, 0) scale(0.95); }
  75%      { transform: translate3d(30px, 20px, 0) scale(1.05); }
}
@keyframes aurora-shift-2 {
  0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
  33%      { transform: translate3d(-50px, 30px, 0) scale(1.08); }
  66%      { transform: translate3d(40px, -25px, 0) scale(0.92); }
}
@keyframes aurora-shift-3 {
  0%, 100% { transform: translate3d(0, 0, 0) scale(0.9); }
  50%      { transform: translate3d(60px, 40px, 0) scale(1.15); }
}

/* === ChatAurora v4 — Pure CSS (Tailwind-purge immune) === */
.chat-aurora-stage {
  position: absolute; inset: 0;
  pointer-events: none;
  transition: opacity 700ms ease-out;
  will-change: opacity;
}
.chat-aurora-stage.is-active { opacity: 1; }
.chat-aurora-stage.is-idle { opacity: 0; }

.aurora-blob {
  position: absolute;
  border-radius: 100%;
  will-change: transform;
  transform: translate3d(0,0,0);
}
.aurora-blob-1 {
  top: -15%; left: -10%;
  width: 700px; height: 700px;
  background: linear-gradient(135deg, #6366f1 0%, #a855f7 50%, #ec4899 100%);
  filter: blur(100px);
}
.aurora-blob-2 {
  bottom: -15%; right: -5%;
  width: 600px; height: 600px;
  background: linear-gradient(45deg, #d946ef 0%, #8b5cf6 50%, #06b6d4 100%);
  filter: blur(90px);
}
.aurora-blob-3 {
  top: 30%; left: 30%;
  width: 500px; height: 500px;
  background: linear-gradient(90deg, #34d399 0%, #2dd4bf 50%, #0ea5e9 100%);
  filter: blur(80px);
}

.aurora-blob-1.is-animating { animation: aurora-shift-1 12s ease-in-out infinite; }
.aurora-blob-2.is-animating { animation: aurora-shift-2 15s ease-in-out infinite reverse; }
.aurora-blob-3.is-animating { animation: aurora-shift-3 18s ease-in-out infinite; }

@keyframes aurora-shift-1 {
  0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
  25%      { transform: translate3d(40px, -30px, 0) scale(1.1); }
  50%      { transform: translate3d(-20px, 40px, 0) scale(0.95); }
  75%      { transform: translate3d(30px, 20px, 0) scale(1.05); }
}
@keyframes aurora-shift-2 {
  0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
  33%      { transform: translate3d(-50px, 30px, 0) scale(1.08); }
  66%      { transform: translate3d(40px, -25px, 0) scale(0.92); }
}
@keyframes aurora-shift-3 {
  0%, 100% { transform: translate3d(0, 0, 0) scale(0.9); }
  50%      { transform: translate3d(60px, 40px, 0) scale(1.15); }
}

.aurora-idle-glow {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 800px; height: 800px;
  border-radius: 100%;
  background: linear-gradient(135deg, #4f46e5 0%, #7e22ce 100%);
  filter: blur(150px);
  opacity: 0.08;
  pointer-events: none;
}

/* === Reasoning / Thinking block (May 27 redesign) === */
@utility overflow-wrap-anywhere {
  overflow-wrap: anywhere;
}

/* Stable reasoning container — prevents layout jitter during streaming
   CRITICAL: Do NOT use size containment — it collapses text flow to single-line.
   Use layout+style+paint containment only. */
.reasoning-text-container {
  position: relative;
  contain: layout style paint;
  content-visibility: auto;
}

/* Smooth text append during streaming — only animate opacity, not layout */
.reasoning-text-container > div {
  transition: none;
}

/* Force monospace + wrapping on all reasoning descendants */
[data-slot="reasoning-text"] *,
.reasoning-text-container * {
  font-family: var(--font-mono), 'JetBrains Mono', 'Fira Code', ui-monospace, monospace !important;
  white-space: pre-wrap !important;
  word-break: break-word !important;
  overflow-wrap: anywhere !important;
}

/* Amber shimmer for the reasoning trigger */
@keyframes reasoning-shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}
.reasoning-shimmer {
  background: linear-gradient(
    110deg,
    transparent 30%,
    rgba(251, 191, 36, 0.08) 50%,
    transparent 70%
  );
  background-size: 200% 100%;
  animation: reasoning-shimmer 2.5s ease-in-out infinite;
}
