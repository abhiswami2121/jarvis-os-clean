import { NextRequest } from "next/server";

const VPS_URL = process.env.JARVIS_VPS_URL || "http://147.93.102.210:8102";

export async function GET(req: NextRequest) {
  const url = new URL(req.url);
  const runId = url.searchParams.get("runId");
  const cursor = url.searchParams.get("cursor");
  if (!runId) return new Response("runId required", { status: 400 });
  const qs = new URLSearchParams({ runId });
  if (cursor) qs.set("cursor", cursor);
  const upstream = await fetch(`${VPS_URL}/v1/chat/resume?${qs.toString()}`);
  return new Response(upstream.body, {
    status: upstream.status,
    headers: { "Content-Type": "text/event-stream", "Cache-Control": "no-cache, no-transform", "X-Accel-Buffering": "no" },
  });
}
export const dynamic = "force-dynamic";
export const runtime = "nodejs";
export const maxDuration = 300;
